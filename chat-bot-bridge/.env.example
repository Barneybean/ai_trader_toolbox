# Messenger bridge credentials — copy to .env and fill in ONE provider's section.
# .env is git-ignored; never commit real values.
# Select one provider explicitly, or let the bridge choose the first configured provider.
PROVIDER=
PROVIDER_PRIORITY=telegram,discord,twilio,meta

# ---- provider: telegram (Bot API long-polling — free, no tunnel) --------------
# Create a bot with @BotFather; its token has a numeric prefix followed by a secret.
# TELEGRAM_ALLOWED_USER_ID is YOUR numeric Telegram user id — the only sender
# the bridge will obey (everyone else who finds the bot is ignored).
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_ID=

# ---- provider: discord (Bot API polling — no tunnel) -------------------------
# Enable the Message Content intent. Required bot permissions: View Channels,
# Read Message History, Send Messages, Attach Files, and Send Messages in Threads.
DISCORD_BOT_TOKEN=
DISCORD_ALLOWED_USER_ID=
DISCORD_CHANNEL_ID=

# ---- shared -----------------------------------------------------------------
# YOUR personal WhatsApp number in digits-only form: country code + number.
# Example: 14155551234 for +1 (415) 555-1234. Only this number can drive the desk.
ALLOWED_WA_ID=

# ---- provider: twilio (sandbox or dedicated sender) --------------------------
# Console dashboard (console.twilio.com) > Account Info
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Sandbox number in whatsapp:+E164 form (shown on the sandbox page)
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# Leave PUBLIC_URL EMPTY for polling mode (outbound HTTPS only — no tunnel, no
# inbound port). Set it to the exact public webhook URL only if you prefer
# webhook mode (then run a tunnel and configure the URL in the Twilio console).
PUBLIC_URL=

# ---- provider: meta (WhatsApp Business Cloud API) -----------------------------
# System-user token (Business Settings > System Users > Generate Token,
# permissions: whatsapp_business_messaging + whatsapp_business_management).
# The temporary token from the API Setup page also works but expires in 24h.
WHATSAPP_TOKEN=
# "Phone number ID" from App Dashboard > WhatsApp > API Setup (the ID, not the phone number)
PHONE_NUMBER_ID=
# App Dashboard > App Settings > Basic > App Secret
APP_SECRET=
# Any random string; must match what you enter in the Meta webhook config.
VERIFY_TOKEN=

# ---- optional overrides -------------------------------------------------------
# Phone agent routing is configurable; /agent auto uses this order.
AGENT_PRIORITY=codex,claude
# Leave models empty to use each authenticated CLI's default model.
CODEX_MODEL=
CLAUDE_MODEL=
# Optional comma-separated Claude model catalog used by routing; keep at most
# the three strongest models you want the bridge to try automatically.
CLAUDE_MODEL_CANDIDATES=
# Leave binaries empty to resolve `codex` and `claude` from PATH.
CODEX_BIN=
CLAUDE_BIN=
# Runs use bounded tool budgets. A report that alone reaches its cap may receive
# one fresh-session completion pass; that pass cannot write broker orders.
# MAX_TOOL_CALLS=120
# REPORT_MAX_TOOL_CALLS=160
# REPORT_RECOVERY_MAX_TOOL_CALLS=24
# MAX_IDENTICAL_TOOL_CALLS=6
# MAX_QUEUE_DEPTH=5
# CODEX_TIMEOUT_MIN=60
# PORT=3000
# POLL_MS=3000
# GRAPH_VERSION=v23.0
