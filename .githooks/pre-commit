#!/usr/bin/env bash
# Gate (local) — blocks a COMMIT that stages PII, credentials, or private knowledge.
set -e
branch="$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo '')"
case "$branch" in
  main|opensource|public|oss|release)
    flags="--staged"; [ -n "${ALLOW_PERSONAL:-}" ] && flags="$flags --allow-knowledge"
    echo "🔒 scan_pii: checking staged changes on public branch '$branch'…"
    if ! python3 scripts/ops/scan_pii.py $flags; then
      echo "✋ commit blocked. PII → move to config.local.toml / .env. Personal knowledge you"
      echo "   deliberately want public → re-run: ALLOW_PERSONAL=1 git commit …"
      exit 1
    fi
    ;;
  *)
    if ! python3 scripts/ops/scan_pii.py --staged --accounts-only; then
      echo "✋ commit blocked: unmasked account identifier. Mask it before committing."
      exit 1
    fi
    ;;
esac
