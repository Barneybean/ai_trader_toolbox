#!/usr/bin/env bash
# PII gate (local) — blocks a COMMIT that stages PII/credentials.
# Only enforced on public branches, so your private branch (main) is never blocked.
set -e
branch="$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo '')"
case "$branch" in
  opensource|public|oss|release)
    echo "🔒 scan_pii: checking staged changes on public branch '$branch'…"
    if ! python3 scripts/scan_pii.py --staged; then
      echo "✋ commit blocked — resolve the findings above, or move the value into"
      echo "   config.local.toml / .env (git-ignored). To bypass once: git commit --no-verify"
      exit 1
    fi
    ;;
  *) : ;;  # private branches are not gated
esac
